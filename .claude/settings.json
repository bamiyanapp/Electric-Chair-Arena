{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.)",
      "Read(/.env)",
      "Read(/.env.)",
      "Read(/*.pem)",
      "Read(/.key)",
      "Edit(.env)",
      "Edit(.env.)",
      "Edit(/.env)",
      "Edit(/.env.)",
      "Edit(**/.pem)",
      "Edit(**/.key)",
      "Bash(cat .env)",
      "Bash(cat /.env)",
      "Bash(cat **/.pem)",
      "Bash(cat **/.key)",
      "Bash(head .env)",
      "Bash(head /.env)",
      "Bash(tail .env)",
      "Bash(tail /.env)",
      "Bash(grep * .env)",
      "Bash(grep * */.env)",

      "Read(**/node_modules/**)",
      "Read(**/vendor/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/out/**)",
      "Read(**/coverage/**)",
      "Edit(**/node_modules/**)",
      "Edit(**/vendor/**)",
      "Edit(**/dist/**)",
      "Edit(**/build/**)",
      "Edit(**/out/**)",
      "Edit(**/coverage/**)",

      "Read(**/package-lock.json)",
      "Read(**/yarn.lock)",
      "Read(**/pnpm-lock.yaml)",
      "Edit(**/package-lock.json)",
      "Edit(**/yarn.lock)",
      "Edit(**/pnpm-lock.yaml)",

      "Read(**/*.min.js)",
      "Read(**/*.map)",
      "Edit(**/*.min.js)",
      "Edit(**/*.map)",

      "Read(**/*.log)",
      "Read(**/*.tmp)",
      "Edit(**/*.log)",
      "Edit(**/*.tmp)",

      "Read(**/*.mp3)",
      "Read(**/*.png)",
      "Read(**/*.svg)",
      "Edit(**/*.mp3)",
      "Edit(**/*.png)",
      "Edit(**/*.svg)",

      "Read(.git/**)",
      "Edit(.git/**)",

      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(rm -rf /:*)"
    ],
    "allow": [
      "Bash(*)",
      "Bash(git *)",
      "Bash(git)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(/bin/ls *)",
      "Bash(/bin/ls)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Skill(*)"
    ]
  }
}